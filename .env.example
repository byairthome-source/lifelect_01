# Database (PostgreSQL — Neon, Supabase, or any PG provider)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Site URL for canonical/meta tags
NEXT_PUBLIC_SITE_URL="https://lifelect.com"

# Vercel Blob Storage (for admin image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
